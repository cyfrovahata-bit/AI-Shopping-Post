OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.4-mini
BOT_TOKEN=
TELEGRAM_CHAT_ID=
ORDER_URL=
INSTAGRAM_USER_ID=
INSTAGRAM_ACCESS_TOKEN=
SITE_URL=
PORT=3000

# Required in production — without a real random value, sessions and encrypted
# per-user tokens fall back to a hardcoded dev secret that's public in this repo,
# letting anyone forge a valid login for any account.
JWT_SECRET=
# Required in production — encrypts per-user social tokens at rest. Falls back to
# JWT_SECRET if unset, so at minimum set JWT_SECRET; ideally set both, separately.
TOKEN_ENCRYPTION_KEY=
# Email of the account allowed to manage shared/global platform config (TikTok and
# OLX app credentials, site URL). Leave unset and those admin routes stay disabled
# for everyone rather than open to any logged-in user.
ADMIN_EMAIL=
